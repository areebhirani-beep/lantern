# ---------------------------------------------------------------------------
# Lantern, environment configuration
# Copy to `.env.local` and fill in. Lantern runs fully WITHOUT these (it falls
# back to verified, cached induction results so the demo always works), but the
# live induction engine + persistent "living corpus" need them.
# ---------------------------------------------------------------------------

# --- LLM provider (pick ONE; Lantern auto-detects) -------------------------
# The induction engine is provider-agnostic. Without any key it serves verified
# cached results; with a key it runs LIVE (and the contribute → re-induce
# flywheel becomes real).

# Option A (recommended, FREE, NO credit card): Groq. Create a key at
# https://console.groq.com/keys in about a minute.
GROQ_API_KEY=
# Advanced: this same slot drives ANY OpenAI-compatible endpoint
# (OpenRouter, Cerebras, Together, GitHub Models, OpenAI). To use one, set:
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.3-70b-versatile

# Option B (FREE): Google Gemini. https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Option C: Anthropic Claude (deepest induction; requires API credits).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# MongoDB Atlas connection string, persists the growing corpus, induced
# vocab, lessons, and contribution events (the flywheel). Without it, Lantern
# uses an in-memory store seeded from the bundled corpora.
MONGODB_URI=
MONGODB_DB=lantern

# --- Accounts (all OPTIONAL; the no-sign-in demo works with none of these) ---
# Auth is purely additive: signing in only ADDS synced SRS progress and
# attributed contributions. Each provider registers only when its keys exist.

# Auth.js v5. Generate AUTH_SECRET with `npx auth secret` or `openssl rand -base64 32`.
AUTH_SECRET=
# http://localhost:3000 in dev; https://lantern-cyan.vercel.app in prod.
AUTH_URL=http://localhost:3000

# Google OAuth, console.cloud.google.com (callback /api/auth/callback/google).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth, github.com > Settings > Developer settings > OAuth Apps.
# One callback per app, so make two apps (dev + prod). Callback /api/auth/callback/github.
GITHUB_ID=
GITHUB_SECRET=

# Firebase / Firestore, the user + per-user data store (from the service-account JSON).
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Keep the \n escapes; wrap the whole value in double quotes.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# AWS S3, user audio recordings + exported course primers (presigned URLs).
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
